# HCI AI Operating System — Infrastructure Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit .env to git.

# ── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_DB=hci_os
POSTGRES_USER=hci_admin
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_strong_password
REDIS_PORT=6379
REDIS_HOST=localhost

# ── MinIO ──────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=hci_admin
MINIO_ROOT_PASSWORD=change_me_strong_password_min_8_chars
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_HOST=localhost

# ── Qdrant ─────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# ── n8n (existing standalone install) ─────────────────────────────────────
# N8N_ENCRYPTION_KEY must match the key in ~/.n8n/ — do not change after setup
N8N_ENCRYPTION_KEY=change_me_must_match_existing_n8n_key

# ── Application ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
HUBSPOT_API_KEY=pat-na2-...
GOOGLE_CREDENTIAL_ID_SHEETS=
GOOGLE_CREDENTIAL_ID_DRIVE=
MS_CREDENTIAL_ID=

# ── Houzz ─────────────────────────────────────────────────────────────────
HOUZZ_EMAIL=
HOUZZ_PASSWORD=

# ── Outlook Inbox Folder IDs ───────────────────────────────────────────────
FOLDER_64_EASTWOOD=
FOLDER_101_FRANCIS=
FOLDER_1355_RIVERSIDE=
FOLDER_83_SAGEBRUSCH=
FOLDER_HCI_ADMIN=

# ── Storage Root (Development Storage & Knowledge Ingestion v1) ────────────
# Leave blank to use named Docker volumes (default — laptop mode).
# Set to external drive mount point to redirect all Docker data to that drive.
# Example (1TB WD dev SSD):  HCI_STORAGE_ROOT=/Volumes/HCI_AI_DEV
# Example (4TB production):  HCI_STORAGE_ROOT=/Volumes/HCI_AI_PROD
# Requires: docker compose -f docker-compose.yml -f docker-compose.storage.yml up -d
HCI_STORAGE_ROOT=
