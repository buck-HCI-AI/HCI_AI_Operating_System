    {
      "id": "d35305ef-853e-442c-be5e-73bf799dbce5",
      "name": "Check Duplicates",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        750,
        300
      ],
      "parameters": {
        "jsCode": "const today = new Date().toISOString().split('T')[0];\nconst data = $('Get Integration Registry').item.json;\n// registered_miners is an array of plain strings (miner names), not objects -\n// found 2026-07-07 the original code assumed item.name/item.display_name\n// existed, which are always undefined for strings, so every item's key\n// collapsed to '' and everything after the first got falsely flagged as a\n// duplicate. Handle both shapes correctly.\nconst items = Array.isArray(data) ? data : (data.registered_miners || []);\nconst seen = {};\nconst dupes = [];\nitems.forEach(item => {\n  const key = (typeof item === 'string' ? item : (item.name || item.display_name || '')).toLowerCase();\n  if (!key) return;\n  if (seen[key]) dupes.push(key);\n  else seen[key] = true;\n});\nconst report = `# Weekly Registry Duplicate Check \u2014 ${today}\n## HCI AI Operating System | AUTO-011\n\n**Generated:** ${new Date().toISOString()}\n\n## Integration Registry Check\n\n- **Items checked:** ${items.length}\n- **Duplicates found:** ${dupes.length}\n${dupes.length > 0 ? '\\n### \u26a0\ufe0f Duplicates:\\n' + dupes.map(d => '- ' + d).join('\\n') : '\\n\u2705 No duplicates detected.'}\n\n---\n\n*AUTO-011 Weekly Registry Check | Hendrickson Construction, Inc.*\n`;\nreturn [{ json: { report, filename: `reports/health/registry-check-${today}.md`, duplicates: dupes.length } }];\n",
        "mode": "runOnceForAllItems"
      }
    },
    {
      "id": "d735e147-7611-46cd-a37b-fba994a1537e",
      "name": "Write & Commit",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1000,
        300
      ],
      "parameters": {
