        "url": "http://host.docker.internal:8000/gateway/admin/write-report",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-API-Key",
              "value": "hci-a4fe3f56f42b981e59a98ec112c43ef975ac68c7fc0517c6"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({filename: $json.filename, content: $json.report}) }}",
        "options": {
          "timeout": 30000
        }
      }
    }
