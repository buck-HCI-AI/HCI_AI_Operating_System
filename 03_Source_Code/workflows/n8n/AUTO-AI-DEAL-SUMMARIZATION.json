      },
      "id": "fetch-active-deals",
      "name": "Fetch Active Deals",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        352,
        304
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "kY88ehAjh5rwI41x",
          "name": "HubSpot API Key (Header Auth)"
        }
      }
    },
    {
      "parameters": {
        "url": "={{ 'https://api.hubapi.com/crm/v3/objects/deals/' + $('Fetch Active Deals').first().json.results[0].id }}/associations/engagements",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": []
        },
        "options": {},
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth"
      },
      "id": "fetch-engagements",
      "name": "Fetch Deal Engagements",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        560,
        304
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "kY88ehAjh5rwI41x",
          "name": "HubSpot API Key (Header Auth)"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Bundle deal + engagements into Claude API prompt\nconst deals = $('Fetch Active Deals').first().json.results || [];\nconst engResp = $input.first().json;\nconst engIds = (engResp.results || []).map(e => e.id).slice(0, 5);\n\n// Build concise deal context\nconst dealSummaries = deals.slice(0, 10).map(d => {\n  const p = d.properties;\n  return `Deal: ${p.dealname} | Stage: ${p.dealstage} | Amount: $${p.amount || 0} | Trade: ${p.tradescope || 'N/A'} | Estimator: ${p.estimator || 'N/A'} | Last Modified: ${p.hs_lastmodifieddate?.split('T')[0]}`;\n}).join('\\n');\n\nconst prompt = `You are the HCI AI Construction OS. Analyze these active HubSpot deals and produce a concise daily briefing for Buck Adams (Owner, Hendrickson Construction).\\n\\nACTIVE DEALS:\\n${dealSummaries}\\n\\nProvide:\\n1. Top 3 deals requiring immediate attention (why + what action)\\n2. Pipeline health summary (1-2 sentences)\\n3. One risk or opportunity flag\\n\\nBe specific and actionable. Max 200 words.`;\n\nreturn [{ json: { prompt, deal_count: deals.length } }];"
      },
      "id": "build-prompt",
      "name": "Build Claude Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        800,
        304
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "options": {},
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({ model: 'claude-haiku-4-5-20251001', max_tokens: 1024, messages: [{ role: 'user', content: $json.prompt }] }) }}"
      },
      "id": "claude-api",
      "name": "Claude API \u2014 Deal Briefing",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1040,
        304
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "3B2e827OvVvAHjj7",
          "name": "Anthropic API Key (Header Auth)"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const resp = $input.first().json;\nconst text = resp.content?.[0]?.text || 'No briefing generated';\nconst dealCount = $('Build Claude Prompt').first().json.deal_count;\nreturn [{ json: { briefing: text, deal_count: dealCount, message: `${dealCount} active deals | ${text.substring(0, 120)}...` } }];"
      },
      "id": "extract-briefing",
      "name": "Extract Briefing",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1280,
        304
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:8000/gateway/ai/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-API-Key",
              "value": "hci-a4fe3f56f42b981e59a98ec112c43ef975ac68c7fc0517c6"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "options": {},
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({ source_agent: 'n8n-auto-ai-deal-summarization', target_agent: 'buck_adams', message_type: 'briefing', title: 'Daily Deal Briefing \u2014 ' + $json.deal_count + ' active deals', body: $json.briefing, priority: 'low' }) }}"
      },
      "id": "post-to-inbox",
      "name": "Post to Executive Inbox",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1520,
        304
      ]
    },
    {
