      },
      "id": "ntfy-renewal",
      "name": "Send Renewal Alert",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1240,
        400
      ]
    },
    {
      "parameters": {
        "jsCode": "// Build daily COI status summary\nconst data = $('Evaluate COI Status').first().json;\nconst s = data.stats;\nconst msg = `COI Daily: ${data.total_companies} companies | Active: ${s.active} | Expired: ${s.expired} | Expiring 30d: ${s.expiringSoon} | Missing: ${s.missing} | Updated: ${data.updates?.length || 0}`;\nconst priority = s.expired > 0 ? 'default' : 'min';\nreturn [{ json: { message: msg, priority } }];"
      },
      "id": "build-summary",
      "name": "Build Daily Summary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
