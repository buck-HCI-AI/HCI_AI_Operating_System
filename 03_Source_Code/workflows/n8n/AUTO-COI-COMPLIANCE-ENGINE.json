    {
      "parameters": {
        "jsCode": "// Evaluate COI status for every company\n// Paginated fetch now returns one item per page \u2014 flatten all pages'\n// results into a single company list instead of only the first page.\nconst companies = $input.all().flatMap(item => (item.json.results || []));\nconst today = new Date();\ntoday.setHours(0,0,0,0);\n\nconst updates = [];\nconst renewalAlerts = [];\nconst stats = { active: 0, expired: 0, expiringSoon: 0, missing: 0, noChange: 0 };\n\nfor (const co of companies) {\n  const props = co.properties || {};\n  const id = co.id;\n  const name = props.name || 'Unknown';\n  const expStr = props.coi_expiration_date;\n  const currentStatus = props.coi_status || 'Missing';\n\n  if (!expStr) {\n    // No expiry date \u2014 mark Missing if not already\n    stats.missing++;\n    if (currentStatus !== 'Missing') {\n      updates.push({ id, name, new_status: 'Missing', reason: 'No COI date on file', days_until_expiry: null });\n    }\n    continue;\n  }\n\n  const expDate = new Date(expStr);\n  expDate.setHours(0,0,0,0);\n  const msPerDay = 1000 * 60 * 60 * 24;\n  const daysUntil = Math.round((expDate - today) / msPerDay);\n\n  let newStatus;\n  if (daysUntil < 0) {\n    newStatus = 'Expired';\n    stats.expired++;\n  } else if (daysUntil <= 30) {\n    newStatus = 'Active';  // still valid but alert needed\n    stats.expiringSoon++;\n    renewalAlerts.push({ id, name, days_until_expiry: daysUntil, expiry_date: expStr });\n  } else {\n    newStatus = 'Active';\n    stats.active++;\n  }\n\n  if (newStatus !== currentStatus) {\n    updates.push({ id, name, new_status: newStatus, old_status: currentStatus, days_until_expiry: daysUntil, expiry_date: expStr });\n  } else {\n    stats.noChange++;\n  }\n}\n\nreturn [{\n  json: {\n    updates,\n    renewal_alerts: renewalAlerts,\n    stats,\n    total_companies: companies.length,\n    has_updates: updates.length > 0,\n    has_renewals: renewalAlerts.length > 0,\n  }\n}];"
      },
      "id": "evaluate-coi",
      "name": "Evaluate COI Status",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        560,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.has_updates }}",
              "value2": true
            }
          ]
        }
      },
      "id": "has-updates",
      "name": "Has Updates?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        800,
        200
      ]
    },
    {
      "parameters": {
        "jsCode": "// Build individual PATCH payloads for each company that needs updating\nconst data = $input.first().json;\nreturn data.updates.map(u => ({\n  json: {\n    company_id: u.id,\n    company_name: u.name,\n    new_status: u.new_status,\n    old_status: u.old_status,\n    days_until_expiry: u.days_until_expiry,\n  }\n}));"
      },
      "id": "split-updates",
      "name": "Split Into Updates",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1020,
        160
      ]
    },
    {
      "parameters": {
        "url": "=https://api.hubapi.com/crm/v3/objects/companies/{{ $json.company_id }}",
        "method": "PATCH",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "options": {},
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ properties: { coi_status: $json.new_status } }) }}"
      },
      "id": "patch-hubspot",
      "name": "Update COI Status in HubSpot",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1240,
        160
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "kY88ehAjh5rwI41x",
          "name": "HubSpot API Key (Header Auth)"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Aggregate all items back into a summary\nconst allItems = $input.all();\nconst updated = allItems.map(i => `${i.json.properties?.name || i.json.company_name || 'Unknown'} \u2192 ${i.json.new_status || '?'}`).join(', ') || 'none';\nreturn [{ json: { updated_companies: updated, count: allItems.length } }];"
      },
      "id": "aggregate-updates",
      "name": "Aggregate Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1460,
        160
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $('Evaluate COI Status').first().json.has_renewals }}",
              "value2": true
            }
          ]
        }
      },
      "id": "has-renewals",
      "name": "Has Renewal Alerts?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        800,
        400
      ]
    },
    {
      "parameters": {
        "jsCode": "// Build renewal alert message\nconst data = $('Evaluate COI Status').first().json;\nconst alerts = data.renewal_alerts || [];\nconst lines = alerts.map(a => `${a.name}: expires ${a.expiry_date} (${a.days_until_expiry} days)`);\nconst urgent = alerts.filter(a => a.days_until_expiry <= 7);\nreturn [{\n  json: {\n    message: lines.join(' | '),\n    priority: urgent.length > 0 ? 'high' : 'default',\n    title: urgent.length > 0 ? `COI URGENT: ${urgent.length} expiring this week` : `COI Renewal: ${alerts.length} expiring within 30 days`,\n  }\n}];"
      },
      "id": "build-renewal-msg",
      "name": "Build Renewal Alert",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1020,
        400
      ]
    },
