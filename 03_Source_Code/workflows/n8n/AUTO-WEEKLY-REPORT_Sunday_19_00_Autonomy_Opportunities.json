              "name": "Expires",
              "value": "24h"
            },
            {
              "name": "Actions",
              "value": "view, View Dashboard, http://host.docker.internal:8000/executive"
            }
          ]
        },
        "sendBody": true,
        "bodyContentType": "raw",
        "rawBody": "={{ $json.pushMsg }} | Cumulative ROI: {{ $json.total_roi }} min/wk",
        "options": {}
      },
      "name": "Push: Opportunities Summary",
