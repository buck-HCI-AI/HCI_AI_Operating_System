        "url": "https://ntfy.sh/hci-executive",
        "method": "POST",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Title",
              "value": "Weekly Automation Opportunities Ready"
            },
            {
              "name": "Tags",
              "value": "robot,chart_with_upwards_trend"
            },
            {
              "name": "Cache",
