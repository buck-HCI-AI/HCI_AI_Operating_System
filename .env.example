# HCI AI Operating System — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.

# n8n
N8N_ENCRYPTION_KEY=your_n8n_encryption_key_here

# PostgreSQL
POSTGRES_PASSWORD=your_secure_postgres_password_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hci_os
POSTGRES_USER=hci_admin

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Redis
REDIS_PASSWORD=your_secure_redis_password_here
REDIS_HOST=localhost
REDIS_PORT=6379

# HubSpot
HUBSPOT_API_KEY=pat-na2-...

# Google (OAuth via n8n credentials — decrypted at runtime)
GOOGLE_CREDENTIAL_ID_SHEETS=Z9ViG2jWlb66ncRi
GOOGLE_CREDENTIAL_ID_DRIVE=UDJZyRl4iZXIr4qI

# Microsoft Graph (OAuth via n8n credentials)
